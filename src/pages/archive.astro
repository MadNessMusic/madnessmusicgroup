---
export const revalidate = 60;

import { releases } from "../data/releases";
import { getSpotifyAlbum } from "../lib/spotify";
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";

interface ReleaseView {
  id: string;
  title: string;
  artist: string;
  image: string;
  url: string;
  type: string;
  releaseDate: string;
  year: number;
  tracks: {
    id: string;
    title: string;
  }[];
}

function detectReleaseType(albumType?: string, tracks?: number) {
  if (albumType === "album") return "Album";
  if (tracks && tracks >= 2 && tracks <= 6) return "EP";
  return "Single";
}

// 🚀 OPTIMIZADO (SIN BATCH + SIN DELAY)
async function fetchReleases() {
  const res = await Promise.allSettled(
    releases.map(async (item) => {
      try {
        const album: any = await getSpotifyAlbum(item.spotifyAlbumId);

        const year = album.releaseDate
          ? new Date(album.releaseDate).getFullYear()
          : 0;

        return {
          id: album.id,
          title: album.title || "Sin titulo",
          artist: album.artist || "Artista no disponible",
          image:
            album.image ||
            item.cover ||
            "/images/releases/coming-soon.png",
          url: album.url || "#",
          type: detectReleaseType(album.type, album.tracks?.length),
          releaseDate: album.releaseDate || "",
          year,
          tracks:
            album.tracks?.map((track: any) => ({
              id: track.id,
              title: track.title,
            })) ?? [],
        };
      } catch (error) {
        return {
          id: item.id,
          title: item.id,
          artist: "Artista no disponible",
          image:
            item.cover || "/images/releases/coming-soon.png",
          url: "#",
          type: "Single",
          releaseDate: "",
          year: 0,
          tracks: [],
        };
      }
    })
  );

  return res
    .filter((r) => r.status === "fulfilled")
    .map((r: any) => r.value);
}

const allReleases: ReleaseView[] = (await fetchReleases()).sort(
  (a, b) =>
    new Date(b.releaseDate || 0).getTime() -
    new Date(a.releaseDate || 0).getTime()
);
---

<Layout />
<Navbar />

<section class="max-w-7xl mx-auto px-6 py-24">
  <h1 class="font-anton text-6xl mb-16">
    Archivo
  </h1>

  <div class="flex flex-wrap items-center gap-6 mb-14 w-full">
    <input
      id="searchInput"
      placeholder="Buscar artista, cancion o lanzamiento..."
      class="flex-2 min-w-70 bg-neutral-900 px-4 py-3 rounded-xl outline-none"
    />

    <select id="yearFilter" class="bg-neutral-900 px-4 py-3 rounded-xl">
      <option value="">Todos los años</option>
    </select>

    <select id="typeFilter" class="bg-neutral-900 px-4 py-3 rounded-xl">
      <option value="">Todos los tipos</option>
      <option value="Single">Single</option>
      <option value="EP">EP</option>
      <option value="Album">Álbum</option>
    </select>
  </div>

  <div id="releaseGrid" class="grid grid-cols-2 md:grid-cols-4 gap-10"></div>

  <p id="noResults" class="opacity-50 mt-10 hidden text-lg font-medium">
    Sin resultados
  </p>

  <div class="flex items-center justify-center gap-4 mt-20">
    <button id="prevPage" class="px-4 py-2 border border-neutral-700">
      ← Anterior
    </button>

    <span id="pageIndicator"></span>

    <button id="nextPage" class="px-4 py-2 border border-neutral-700">
      Siguiente →
    </button>
  </div>
</section>

<div id="shareModal" class="fixed inset-0 z-999 hidden items-center justify-center bg-black/80 backdrop-blur-md">

  <div class="bg-neutral-900 rounded-2xl p-6 max-w-md w-full mx-4">

    <!-- IMAGE PREVIEW -->
    <img id="sharePreview" class="w-full rounded-xl mb-4" />

    <!-- BUTTONS -->
    <div class="flex gap-3">

      <button id="shareAction" class="flex-1 bg-white text-black py-3 rounded-xl font-semibold">
        Compartir
      </button>

      <button id="downloadAction" class="flex-1 bg-neutral-800 py-3 rounded-xl">
        Descargar
      </button>

      <button id="closeModal" class="px-4 bg-neutral-700 rounded-xl">
        ✕
      </button>

    </div>

  </div>
</div>

<script define:vars={{ allReleases }}>
  const releasesData = allReleases;

  const grid = document.getElementById("releaseGrid");
  const noResults = document.getElementById("noResults");
  const searchInput = document.getElementById("searchInput");
  const yearFilter = document.getElementById("yearFilter");
  const typeFilter = document.getElementById("typeFilter");
  const prevBtn = document.getElementById("prevPage");
  const nextBtn = document.getElementById("nextPage");
  const pageIndicator = document.getElementById("pageIndicator");

  let filtered = [...releasesData];
  let page = 1;
  const perPage = 12;

  const years = [...new Set(releasesData.map((r) => r.year).filter(Boolean))].sort(
    (a, b) => b - a
  );

  years.forEach((year) => {
    const option = document.createElement("option");
    option.value = String(year);
    option.textContent = String(year);
    yearFilter.appendChild(option);
  });

  function applyFilters() {
    const query = searchInput.value.toLowerCase();
    const year = yearFilter.value;
    const type = typeFilter.value;

    filtered = releasesData.filter((release) => {
      const trackMatch = release.tracks.some((track) =>
        track.title.toLowerCase().includes(query)
      );

      const matchSearch =
        release.title.toLowerCase().includes(query) ||
        release.artist.toLowerCase().includes(query) ||
        trackMatch;

      const matchYear = !year || String(release.year) === year;
      const matchType = !type || release.type === type;

      return matchSearch && matchYear && matchType;
    });

    page = 1;
    render();
  }

  function render() {
    grid.innerHTML = "";

    const start = (page - 1) * perPage;
    const end = start + perPage;
    const pageItems = filtered.slice(start, end);
    const totalPages = Math.max(1, Math.ceil(filtered.length / perPage));

    noResults.classList.toggle("hidden", filtered.length > 0);

    pageItems.forEach((release) => {
      const el = document.createElement("div");
      el.className = "group";

      el.innerHTML = `
<div>

  <!-- IMAGE WRAPPER -->
  <div class="relative rounded-2xl overflow-hidden group">

          <button 
        class="share-btn absolute top-3 right-3 z-40 w-15 h-15 flex items-center justify-center rounded-full bg-black/60 backdrop-blur-xl border border-white/20 shadow-xl active:scale-90 transition"
        data-url="${release.url}"
        data-title="${release.title}"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="23" height="23" fill="none" stroke="currentColor" class="text-white" stroke-width="2">
          <path d="M4 12v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"/>
          <path d="M12 16V4"/>
          <path d="M8 8l4-4 4 4"/>
        </svg>
      </button>

    <!-- IMAGE -->
    <a href="${release.url}" target="_blank">
      <img 
        src="${release.image}" 
        loading="lazy"
        class="w-full aspect-square object-cover transition duration-500 group-hover:scale-105"
      />
    </a>

    <!-- OVERLAY (SOLO IMAGEN) -->
    <div class="absolute inset-0 z-20 opacity-0 group-hover:opacity-100 transition duration-300">

      <!-- SHARE BUTTON -->


      <!-- GRADIENT + PLAY -->
      <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent flex flex-col justify-end p-4">

        <a href="${release.url}" target="_blank"
          class="w-12 h-12 rounded-full bg-green-500 flex items-center justify-center text-black text-xl shadow-lg active:scale-95 transition"
        >
          ▶
        </a>

        <span class="text-[10px] tracking-widest uppercase opacity-80 mt-2">
          Escuchar en Spotify
        </span>

      </div>
    </div>
  </div>

  <!-- INFO (FUERA DEL OVERLAY) -->
  <div class="mt-3">
    <p class="font-anton text-sm sm:text-base">${release.title}</p>
    <p class="text-xs sm:text-sm opacity-60">${release.artist}</p>

    <div class="mt-2 flex items-center gap-2">
      <span class="text-[9px] uppercase opacity-50">${release.type}</span>
      <span class="w-1.5 h-1.5 rounded-full ${
        release.type === "Single"
          ? "bg-green-400"
          : release.type === "EP"
          ? "bg-purple-400"
          : "bg-blue-400"
      }"></span>
    </div>

    <p class="text-[9px] uppercase opacity-30 mt-1">
      ${release.releaseDate || ""}
    </p>
  </div>

</div>
`;

      grid.appendChild(el);
    });

    pageIndicator.textContent = `${page} / ${totalPages}`;
    prevBtn.disabled = page <= 1;
    nextBtn.disabled = page >= totalPages;
  }

  searchInput.addEventListener("input", applyFilters);
  yearFilter.addEventListener("change", applyFilters);
  typeFilter.addEventListener("change", applyFilters);

  prevBtn.onclick = () => {
    if (page > 1) {
      page--;
      render();
    }
  };

  nextBtn.onclick = () => {
    const totalPages = Math.max(1, Math.ceil(filtered.length / perPage));
    if (page < totalPages) {
      page++;
      render();
    }
  };

let currentImage = null;
let currentBlob = null;
let currentTitle = "";

document.addEventListener("click", async (e) => {
  const btn = e.target.closest(".share-btn");
  if (!btn) return;

  e.preventDefault();
  e.stopPropagation();

  const card = btn.closest(".group");

  const imgEl = card.querySelector("img");
  const image = imgEl?.currentSrc || imgEl?.src;
  const title = btn.dataset.title;
  const artist = card.querySelector(".mt-3 p:nth-child(2)")?.textContent || "";

  const result = await generateCard({ image, title, artist });

  currentImage = result.url;
  currentBlob = result.blob;
  currentTitle = title;

  document.getElementById("sharePreview").src = currentImage;
  document.getElementById("shareModal").classList.remove("hidden");
});

// ❌ CLOSE
document.getElementById("closeModal").onclick = () => {
  document.getElementById("shareModal").classList.add("hidden");
};

// 💾 DOWNLOAD
document.getElementById("downloadAction").onclick = () => {
  const link = document.createElement("a");
  link.download = `${currentTitle}.png`;
  link.href = currentImage;
  link.click();
};

// 📱 SHARE
document.getElementById("shareAction").onclick = async () => {
  const file = new File([currentBlob], "track.png", { type: "image/png" });

  if (navigator.canShare && navigator.canShare({ files: [file] })) {
    try {
      await navigator.share({
        files: [file],
        title: currentTitle,
      });
    } catch {}
  } else {
    alert("Tu dispositivo no soporta compartir imágenes");
  }
};

document.getElementById("shareModal").addEventListener("click", (e) => {
  if (e.target.id === "shareModal") {
    e.currentTarget.classList.add("hidden");
  }
});

  render();


 async function generateCard({ image, title, artist }) {
  const canvas = document.createElement("canvas");
  const ctx = canvas.getContext("2d");

  canvas.width = 1080;
  canvas.height = 1350;

  // 🖼 IMAGE
  const img = new Image();
  img.crossOrigin = "anonymous";
  img.src = image;

  await new Promise((res, rej) => {
    img.onload = res;
    img.onerror = rej;
  });

  // 🌌 BACKGROUND BLUR
  for (let i = 0; i < 20; i++) {
  const offset = i * 2;

  ctx.globalAlpha = 0.08;
  ctx.drawImage(
    img,
    -offset,
    -offset,
    canvas.width + offset * 2,
    canvas.height + offset * 2
  );
}

ctx.globalAlpha = 1;

  ctx.fillStyle = "rgba(0,0,0,0.6)";
  ctx.fillRect(0, 0, canvas.width, canvas.height);

  // 🎵 COVER
  const size = 720;
  const x = (canvas.width - size) / 2;
  const y = 150;

  ctx.shadowColor = "rgba(0,0,0,0.6)";
  ctx.shadowBlur = 50;
  ctx.drawImage(img, x, y, size, size);

  ctx.shadowBlur = 0;

  // 📝 TITLE
  const padding = 80;
const textWidth = canvas.width - padding * 2;
  ctx.fillStyle = "white";
  ctx.textAlign = "left";

  ctx.font = "bold 56px sans-serif";
  ctx.fillStyle = "rgba(255,255,255,0.9)";
 wrapText(ctx, title, padding, 980, textWidth, 70);

  // 🎤 ARTIST
  ctx.font = "36px sans-serif";
  ctx.fillStyle = "rgba(255,255,255,0.6)";
  ctx.fillText(artist, padding, 1120);

  // 🔥 LOGO
  const logo = new Image();
  logo.crossOrigin = "anonymous";
  logo.src = "/logo.png"; // 👈 CAMBIA ESTO

  try {
    await new Promise((res) => (logo.onload = res));

    const logoWidth = 200;
    const logoHeight = 60;

    ctx.globalAlpha = 0.9;
    ctx.drawImage(
      logo,
      canvas.width - logoWidth - 60,
      canvas.height - logoHeight - 60,
      logoWidth,
      logoHeight
    );
    ctx.globalAlpha = 1;
  } catch {}

// EXPORT
const blob = await new Promise((resolve) =>
  canvas.toBlob(resolve, "image/png")
);

const url = URL.createObjectURL(blob);

// 👇 IMPORTANTE: devolver datos
return { blob, url };
}

function wrapText(ctx, text, x, y, maxWidth, lineHeight) {
  const words = text.split(" ");
  let line = "";

  for (let n = 0; n < words.length; n++) {
    const testLine = line + words[n] + " ";
    const metrics = ctx.measureText(testLine);
    const testWidth = metrics.width;

    if (testWidth > maxWidth && n > 0) {
      ctx.fillText(line, x, y);
      line = words[n] + " ";
      y += lineHeight;
    } else {
      line = testLine;
    }
  }

  ctx.fillText(line, x, y);
}

</script>
