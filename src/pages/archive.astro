        <path d="M4 12v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"/>
        <path d="M12 16V4"/>
        <path d="M8 8l4-4 4 4"/>
      </svg>
    </button>

    <!-- IMAGE -->
    <a href="${release.url}" target="_blank" class="block aspect-square">
