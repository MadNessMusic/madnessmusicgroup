---
import { releases } from "../data/releases";
import { getSpotifyAlbum } from "../lib/spotify";
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro"

interface ReleaseView {
  id: string;
  title: string;
  artist: string;
  image: string;
  url: string;
  type: string;
  releaseDate: string;
  year: number;
  tracks: {
    id: string
    title: string
  }[]
}

function detectReleaseType(albumType?: string, tracks?: number) {

  if (albumType === "album") return "Album"

  if (tracks && tracks >= 2 && tracks <= 6)
    return "EP"

  return "Single"

}

const allReleases: ReleaseView[] = (
  await Promise.all(
    releases.map(async (item) => {

      const album = await getSpotifyAlbum(item.spotifyAlbumId);

      const year = new Date(album.releaseDate).getFullYear()

      return {
        id: album.id,
        title: album.title,
        artist: album.artist,
        image: album.image,
        url: album.url,
        type: detectReleaseType(album.type, album.tracks?.length),
        releaseDate: album.releaseDate,
        year,
        tracks: album.tracks
      };

    })
  )
).sort((a,b)=> new Date(b.releaseDate).getTime() - new Date(a.releaseDate).getTime());
---

<Layout />
<Navbar />

<section class="max-w-7xl mx-auto px-6 py-24">

<h1
class="font-anton text-6xl mb-16"
data-i18n="archive.title">
</h1>

<!-- CONTROLES -->

<div class="flex flex-wrap items-center gap-6 mb-14 w-full">

<input
id="searchInput"
placeholder="Search artist, track or release..."
data-i18n-placeholder="archive.search"
class="flex-2 min-w-70 bg-neutral-900 px-4 py-3 rounded-xl outline-none"
/>

<select id="yearFilter" class="bg-neutral-900 px-4 py-3 rounded-xl">
<option value="" data-i18n="archive.years.all"></option>
</select>

<select id="typeFilter" class="bg-neutral-900 px-4 py-3 rounded-xl">

<option value="" data-i18n="archive.types.all"></option>
<option value="Single" data-i18n="release.type.single"></option>
<option value="EP" data-i18n="release.type.ep"></option>
<option value="Album" data-i18n="release.type.album"></option>

</select>

</div>

<!-- GRID -->

<div
id="releaseGrid"
class="grid grid-cols-2 md:grid-cols-4 gap-10"
></div>

<p
id="noResults"
class="opacity-50 mt-10 hidden text-lg font-medium"
data-i18n="archive.showingAll">
</p>

<!-- PAGINACION -->

<div class="flex items-center justify-center gap-4 mt-20">

<button
id="prevPage"
class="px-4 py-2 rounded-lg border border-neutral-700 transition disabled:opacity-40 disabled:cursor-not-allowed hover:bg-neutral-800"
>
<span data-i18n="pagination.prev"></span>
</button>

<span
id="pageIndicator"
class="text-sm opacity-60 min-w-20 text-center"
></span>

<button
id="nextPage"
class="px-4 py-2 rounded-lg border border-neutral-700 transition disabled:opacity-40 disabled:cursor-not-allowed hover:bg-neutral-800"
>
<span data-i18n="pagination.next"></span>
</button>

</div>

</section>

<script define:vars={{ allReleases }}>

const releases = allReleases

const grid = document.getElementById("releaseGrid")

const searchInput = document.getElementById("searchInput")
const yearFilter = document.getElementById("yearFilter")
const typeFilter = document.getElementById("typeFilter")

const prevBtn = document.getElementById("prevPage")
const nextBtn = document.getElementById("nextPage")
const pageIndicator = document.getElementById("pageIndicator")

let filtered = [...releases]

let page = 1
const perPage = 12

// llenar filtro de años

const years = [...new Set(releases.map(r => r.year))].sort((a,b)=>b-a)

years.forEach(y=>{
const opt = document.createElement("option")
opt.value = y
opt.textContent = y
yearFilter.appendChild(opt)
})

function applyFilters(){

const q = searchInput.value.toLowerCase()
const year = yearFilter.value
const type = typeFilter.value

filtered = releases.filter(r=>{

const trackMatch = r.tracks.some(t =>
t.title.toLowerCase().includes(q)
)

const matchSearch =
r.title.toLowerCase().includes(q) ||
r.artist.toLowerCase().includes(q) ||
trackMatch

const matchYear = !year || r.year == year

const matchType = !type || r.type === type

return matchSearch && matchYear && matchType

})

page = 1

render()

}

function getTypeColor(type){

if(type==="Single") return "text-green-400"
if(type==="EP") return "text-purple-400"

return "text-blue-400"

}

function render(){

grid.innerHTML = ""

const start = (page - 1) * perPage
const end = start + perPage

const pageItems = filtered.slice(start, end)

pageItems.forEach(r => {

const el = document.createElement("div")

el.className =
"group opacity-0 translate-y-4 transition duration-500"

el.innerHTML = `
<div class="group">

<!-- COVER -->

<div class="relative aspect-square rounded-xl overflow-hidden group">

<img
src="${r.image}"
class="w-full h-full object-cover transition duration-500 group-hover:scale-105"
/>

<!-- overlay -->

<div class="absolute inset-0 bg-black/30 opacity-0 group-hover:opacity-100 transition hidden md:block"></div>

<!-- SHARE DESKTOP -->

<button
class="hover:cursor-pointer shareBtn hidden md:flex absolute top-3 right-3 z-20 items-center gap-1 text-xs bg-black/70 backdrop-blur border border-white/20 px-3 py-1.5 rounded-full shadow-lg opacity-0 group-hover:opacity-100 transition hover:scale-105"
data-title="${r.title}"
data-artist="${r.artist}"
data-cover="${r.image}"
data-url="${r.url}"
>

<svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
<path d="M4 12v7a1 1 0 001 1h14a1 1 0 001-1v-7"/>
<path d="M16 6l-4-4-4 4"/>
<path d="M12 2v14"/>
</svg>

<span data-i18n="release.share">Compartir</span>

</button>

<!-- SPOTIFY DESKTOP -->

<a
href="${r.url}"
target="_blank"
class="hidden md:flex absolute bottom-3 left-3 z-20 items-center gap-2 text-sm bg-[#1DB954] text-black px-4 py-2 rounded-full font-bold shadow-lg hover:scale-105 hover:bg-[#1ed760] transition opacity-0 group-hover:opacity-100"
>

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 168 168" class="w-4 h-4 fill-black">
<path d="M84 0a84 84 0 1 0 0 168 84 84 0 0 0 0-168zm38.6 121.3c-1.5 2.5-4.7 3.3-7.2 1.8-19.8-12.1-44.8-14.8-74.4-8-2.8.6-5.5-1.1-6.1-3.9-.6-2.8 1.1-5.5 3.9-6.1 32.3-7.4 60-4.3 82 9.2 2.5 1.5 3.3 4.7 1.8 7.2z"/>
</svg>

<span data-i18n="release.listenSpotify">Escuchar en Spotify</span>

</a>

</div>

</div>

<!-- TEXT -->

<div class="mt-3">

<p class="font-anton text-lg leading-tight">
${r.title}
</p>

<p class="text-sm opacity-70">
${r.artist}
</p>

<p class="text-[10px] uppercase mt-1 ${getTypeColor(r.type)} tracking-wide">
${r.type}
</p>

</div>

<!-- MOBILE ACTIONS (minimal) -->

<div class="flex md:hidden gap-3 mt-3">

<a
href="${r.url}"
target="_blank"
class="flex-1 flex items-center justify-center bg-[#1DB954] text-black py-2 rounded-lg"
>

<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 168 168" class="w-5 h-5 fill-black">
<path d="M84 0a84 84 0 1 0 0 168 84 84 0 0 0 0-168zm38.6 121.3c-1.5 2.5-4.7 3.3-7.2 1.8-19.8-12.1-44.8-14.8-74.4-8-2.8.6-5.5-1.1-6.1-3.9-.6-2.8 1.1-5.5 3.9-6.1 32.3-7.4 60-4.3 82 9.2 2.5 1.5 3.3 4.7 1.8 7.2z"/>
</svg>

</a>

<button
class="shareBtn flex-1 flex items-center justify-center bg-neutral-800 py-2 rounded-lg"
data-title="${r.title}"
data-artist="${r.artist}"
data-cover="${r.image}"
data-url="${r.url}"
>

<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
<path d="M4 12v7a1 1 0 001 1h14a1 1 0 001-1v-7"/>
<path d="M16 6l-4-4-4 4"/>
<path d="M12 2v14"/>
</svg>

</button>

</div>

<!-- SHARE MENU GLOBAL -->

<div id="shareMenu" class="hidden fixed inset-0 bg-black/70 flex items-center justify-center z-50">

<div class="bg-neutral-900 p-6 rounded-xl space-y-4 w-72">

<button id="igStory" class="w-full bg-pink-500 py-3 rounded-lg">
Instagram Story
</button>

<button id="fbStory" class="w-full bg-blue-500 py-3 rounded-lg">
Facebook Story
</button>

<button id="download" class="w-full bg-neutral-700 py-3 rounded-lg">
Download Image
</button>

<button id="copyLink" class="w-full bg-neutral-800 py-3 rounded-lg">
Copy Link
</button>

</div>

</div>

</div>
`

grid.appendChild(el)

requestAnimationFrame(()=>{
el.classList.remove("opacity-0","translate-y-4")
})

})

updatePagination()

// Subir al inicio de la página al renderizar
window.scrollTo({ top: 175, behavior: "smooth" });

}

function updatePagination(){

const totalPages = Math.ceil(filtered.length / perPage)

const indicator = document.getElementById("pageIndicator")
const paginationContainer = prevBtn.parentElement
const message = document.getElementById("noResults")

// NO HAY RESULTADOS
if(filtered.length === 0){

paginationContainer.style.display = "none"

message.classList.remove("hidden")
message.setAttribute("data-i18n","archive.showingAll")

if(window.applyTranslations) applyTranslations()

return

}

// SOLO UNA PAGINA (MOSTRAR TODOS)
if(totalPages === 1){

paginationContainer.style.display = "none"

message.classList.remove("hidden")
message.setAttribute("data-i18n","archive.showingAll")

if(window.applyTranslations) applyTranslations()

return

}

// HAY VARIAS PAGINAS
paginationContainer.style.display = "flex"

message.classList.add("hidden")

indicator.textContent = page + " / " + totalPages

prevBtn.disabled = page === 1
nextBtn.disabled = page === totalPages

}

searchInput.addEventListener("input",applyFilters)
yearFilter.addEventListener("change",applyFilters)
typeFilter.addEventListener("change",applyFilters)

prevBtn.onclick=()=>{

if(page === 1) return

page--
render()

}

nextBtn.onclick=()=>{

const totalPages = Math.ceil(filtered.length / perPage)

if(page === totalPages) return

page++
render()

}

render()

document.addEventListener("click", (e) => {
  const btn = e.target.closest(".shareBtn");
  if (!btn) return;

  generateShareImage({
    title: btn.dataset.title,
    artist: btn.dataset.artist,
    cover: btn.dataset.cover,
    logo: "src/assets/MadNess Music Group - Logo White.png"
  });
});

async function generateShareImage({ title, artist, cover, logo }) {
  const canvas = document.createElement("canvas");
  canvas.width = 1080;
  canvas.height = 1080;
  const ctx = canvas.getContext("2d");

  const img = new Image();
  img.crossOrigin = "anonymous";
  img.src = cover;
  await img.decode();

  // ---- fondo blur ----
  const tempCanvas = document.createElement("canvas");
  tempCanvas.width = 1080;
  tempCanvas.height = 1080;
  const tempCtx = tempCanvas.getContext("2d");
  tempCtx.drawImage(img, 0, 0, 1080, 1080);

  ctx.filter = "blur(50px)";
  ctx.drawImage(tempCanvas, 0, 0, 1080, 1080);
  ctx.filter = "none";

  // gradiente sobre blur
  const gradient = ctx.createLinearGradient(0, 0, 0, 1080);
  gradient.addColorStop(0, "rgba(0,0,0,0.2)");
  gradient.addColorStop(1, "rgba(0,0,0,0.8)");
  ctx.fillStyle = gradient;
  ctx.fillRect(0, 0, 1080, 1080);

  // ---- cover principal ----
  const coverSize = 700;
  const coverX = (1080 - coverSize) / 2;
  const coverY = 60; // subimos un poco
  ctx.drawImage(img, coverX, coverY, coverSize, coverSize);

  // ---- texto adaptativo a la izquierda ----
  const textX = 90; // margen izquierdo
  const maxTextWidth = 1080 * 0.9; // 80% del ancho
  ctx.textAlign = "left";
  ctx.fillStyle = "#fff";

  // título adaptativo
  let titleFontSize = 72;
  ctx.font = `bold ${titleFontSize}px sans-serif`;
  while (ctx.measureText(title).width > maxTextWidth && titleFontSize > 30) {
    titleFontSize -= 2;
    ctx.font = `bold ${titleFontSize}px sans-serif`;
  }
  const titleLineHeight = titleFontSize + 10;
  const titleLines = wrapTextMeasure(ctx, title, maxTextWidth);

  // artista(s)
  const artistFontSize = 40;
  ctx.font = `${artistFontSize}px sans-serif`;
  const artistLineHeight = artistFontSize + 20;
  const artistLines = wrapTextMeasure(ctx, artist, maxTextWidth);

  // calcular Y inicial centrado bajo cover
  let startY = coverY + coverSize + 100;

  // dibujar título
  ctx.font = `bold ${titleFontSize}px sans-serif`;
  titleLines.forEach((line, i) => {
    ctx.fillText(line, textX, startY + i * titleLineHeight);
  });

  // dibujar artista
  ctx.font = `${artistFontSize}px sans-serif`;
  ctx.globalAlpha = 0.8;
  artistLines.forEach((line, i) => {
    ctx.fillText(line, textX, startY + titleLineHeight * titleLines.length + i * artistLineHeight);
  });
  ctx.globalAlpha = 1;

  // ---- logo proporcional más pequeño ----
  if (logo) {
    const logoImg = new Image();
    logoImg.src = logo;
    await logoImg.decode();

    const maxLogoHeight = 80;
    let logoWidth = logoImg.width;
    let logoHeight = logoImg.height;
    if (logoHeight > maxLogoHeight) {
      const scale = maxLogoHeight / logoHeight;
      logoHeight = maxLogoHeight;
      logoWidth = logoWidth * scale;
    }

    // logo en blanco
    const logoCanvas = document.createElement("canvas");
    logoCanvas.width = logoWidth;
    logoCanvas.height = logoHeight;
    const logoCtx = logoCanvas.getContext("2d");
    logoCtx.drawImage(logoImg, 0, 0, logoWidth, logoHeight);
    logoCtx.globalCompositeOperation = "source-in";
    logoCtx.fillStyle = "#fff";
    logoCtx.fillRect(0, 0, logoWidth, logoHeight);

    ctx.drawImage(logoCanvas, 1080 - logoWidth - 20, 1080 - logoHeight - 20, logoWidth, logoHeight);
  }

  showModal(canvas, title);
}

// ---- wrap de texto y medición ----
function wrapTextMeasure(ctx, text, maxWidth) {
  const words = text.split(" ");
  const lines = [];
  let line = "";
  for (let n = 0; n < words.length; n++) {
    const testLine = line + words[n] + " ";
    const metrics = ctx.measureText(testLine);
    if (metrics.width > maxWidth && n > 0) {
      lines.push(line.trim());
      line = words[n] + " ";
    } else {
      line = testLine;
    }
  }
  lines.push(line.trim());
  return lines;
}

// ---- modal con íconos ----
function showModal(canvas, title) {
  const modal = document.createElement("div");
  modal.style.position = "fixed";
  modal.style.top = 0;
  modal.style.left = 0;
  modal.style.width = "100vw";
  modal.style.height = "100vh";
  modal.style.background = "rgba(0,0,0,0.5)";
  modal.style.backdropFilter = "blur(8px)";
  modal.style.display = "flex";
  modal.style.justifyContent = "center";
  modal.style.alignItems = "center";
  modal.style.zIndex = 9999;
  modal.style.opacity = 0;
  modal.style.transition = "opacity 0.3s ease";

  const container = document.createElement("div");
  container.style.position = "relative";
  container.style.background = "#111";
  container.style.padding = "15px";
  container.style.borderRadius = "20px";
  container.style.boxShadow = "0 0 40px rgba(0,0,0,0.5)";
  container.style.display = "flex";
  container.style.flexDirection = "column";
  container.style.alignItems = "center";
  container.style.maxWidth = "500px";
  container.style.maxHeight = "80vh";
  container.style.animation = "fadeInScale 0.3s ease forwards";

  const imgEl = document.createElement("img");
  imgEl.src = canvas.toDataURL("image/png");
  imgEl.style.maxWidth = "100%";
  imgEl.style.maxHeight = "70vh";
  imgEl.style.borderRadius = "16px";
  imgEl.style.boxShadow = "0 0 20px rgba(0,0,0,0.5)";
  container.appendChild(imgEl);

  const btnContainer = document.createElement("div");
  btnContainer.style.display = "flex";
  btnContainer.style.gap = "15px";
  btnContainer.style.marginTop = "15px";

  const downloadBtn = document.createElement("button");
  downloadBtn.innerHTML = "💾";
  downloadBtn.title = "Descargar";
  downloadBtn.style.fontSize = "24px";
  downloadBtn.style.padding = "10px 20px";
  downloadBtn.onclick = () => {
    const link = document.createElement("a");
    link.download = `madness-${title.replace(/\s+/g, "-").toLowerCase()}.png`;
    link.href = canvas.toDataURL("image/png");
    link.click();
    document.body.removeChild(modal);
  };

  const cancelBtn = document.createElement("button");
  cancelBtn.innerHTML = "❌";
  cancelBtn.title = "Cancelar";
  cancelBtn.style.fontSize = "24px";
  cancelBtn.style.padding = "10px 20px";
  cancelBtn.onclick = () => document.body.removeChild(modal);

  btnContainer.appendChild(downloadBtn);
  btnContainer.appendChild(cancelBtn);
  container.appendChild(btnContainer);

  const closeBtn = document.createElement("span");
  closeBtn.textContent = "×";
  closeBtn.style.position = "absolute";
  closeBtn.style.top = "10px";
  closeBtn.style.right = "15px";
  closeBtn.style.fontSize = "24px";
  closeBtn.style.cursor = "pointer";
  closeBtn.style.color = "#fff";
  closeBtn.onclick = () => document.body.removeChild(modal);
  container.appendChild(closeBtn);

  modal.appendChild(container);
  document.body.appendChild(modal);

  requestAnimationFrame(() => {
    modal.style.opacity = 1;
  });

  const style = document.createElement("style");
  style.innerHTML = `
    @keyframes fadeInScale {
      0% { transform: scale(0.8); opacity: 0; }
      100% { transform: scale(1); opacity: 1; }
    }
  `;
  document.head.appendChild(style);
}

</script>

