    <span id="pageIndicator"></span>

    <button id="nextPage" class="px-4 py-2 border border-neutral-700">
      Siguiente →
    </button>
  </div>
</section>




<script define:vars={{ allReleases }}>
const releasesData = allReleases;

const grid = document.getElementById("releaseGrid");

let filtered = [...releasesData];

const searchInput = document.getElementById("searchInput");
const yearFilter = document.getElementById("yearFilter");
const typeFilter = document.getElementById("typeFilter");
const sourceFilter = document.getElementById("sourceFilter");

let currentImage = null;
let currentBlob = null;
let currentTitle = "";
let currentArtist = "";
let currentStyle = "vibrant";
let originalImage = "";
let currentUrl = "";

function populateYears() {
  const years = [...new Set(releasesData.map(r => r.year))].sort((a,b) => b-a);

  years.forEach(y => {
    const opt = document.createElement("option");
    opt.value = y;
    opt.textContent = y;
    yearFilter.appendChild(opt);
  });
}

populateYears();

function applyFilters() {
  const search = searchInput.value.toLowerCase();
  const year = yearFilter.value;
  const type = typeFilter.value;
  const source = sourceFilter.value;

  filtered = releasesData.filter(r => {
    const matchesSearch =
      r.title.toLowerCase().includes(search) ||
      r.artist.toLowerCase().includes(search);

    const matchesYear = year ? r.year == year : true;
    const matchesType = type ? r.type === type : true;
    const matchesSource = source ? r.source === source : true;

    return matchesSearch && matchesYear && matchesType && matchesSource;
  });

  renderFiltered();
}

function renderFiltered() {
  grid.innerHTML = "";

  if (!filtered.length) {
    document.getElementById("noResults").classList.remove("hidden");
    return;
  }

  document.getElementById("noResults").classList.add("hidden");

