  <button id="closeModal"
    class="w-12 h-12 rounded-xl bg-neutral-800 hover:bg-neutral-700 transition cursor-pointer">
    ✕
  </button>
</div>

  </div>
</div>


  <div id="releaseGrid" class="grid grid-cols-2 md:grid-cols-4 gap-10"></div>

  <p id="noResults" class="opacity-50 mt-10 hidden text-lg font-medium">
    Sin resultados
