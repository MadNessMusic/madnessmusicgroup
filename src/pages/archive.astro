      />
    </a>

    <!-- OVERLAY -->
    <div class="absolute inset-0 z-20 opacity-0 group-hover:opacity-100 transition duration-300 backdrop-blur-md">

      <div class="absolute inset-0 bg-black/20 flex flex-col justify-end gap-3 p-5">

        <!-- PLAY PRO -->
        <a href="${release.url}" target="_blank"
