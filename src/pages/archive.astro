// CLICK SHARE
document.addEventListener("click", async (e) => {
  const btn = e.target.closest(".share-btn");
  if (!btn) return;

  e.preventDefault();
  e.stopPropagation();

  const card = btn.closest(".group");
  const imgEl = card.querySelector("img");

  const image = imgEl?.currentSrc || imgEl?.src;
  const title = btn.dataset.title;
  const artist = btn.dataset.artist;

  // 🔥 guardar
  currentTitle = title;
  currentArtist = artist;
  originalImage = image;
  currentUrl = btn.closest(".group").querySelector("a")?.href || "";

  const result = await generateCard({
    image,
    title,
    artist,
    style: currentStyle
  });

  currentImage = result.url;
  currentBlob = result.blob;

  document.getElementById("sharePreview").src = currentImage;

  const modal = document.getElementById("shareModal");
  modal.classList.remove("hidden");
  modal.classList.add("flex");

  // activar default
  setActiveStyle("vibrant");
});

// CLOSE
document.getElementById("closeModal").onclick = () => {
  const modal = document.getElementById("shareModal");
  modal.classList.add("hidden");
  modal.classList.remove("flex");
};

// DOWNLOAD
document.getElementById("downloadAction").onclick = () => {
  const link = document.createElement("a");
  link.download = `${currentTitle}.png`;
  link.href = currentImage;
  link.click();
};

document.getElementById("shareAction").onclick = async () => {
  try {
    // 📋 copiar link
    if (currentUrl) {
      await navigator.clipboard.writeText(currentUrl);
    }

    // 📱 compartir imagen
    const file = new File([currentBlob], "track.png", { type: "image/png" });

    if (navigator.canShare && navigator.canShare({ files: [file] })) {
      await navigator.share({
        files: [file],
        title: currentTitle,
      });
    }

    // 🔥 FEEDBACK VISUAL
    showToast("Link copiado 🔥 listo para pegar en Instagram");

  } catch {
    showToast("Error al compartir");
  }
};

// CLICK OUTSIDE
document.getElementById("shareModal").addEventListener("click", (e) => {
  if (e.target.id === "shareModal") {
    e.currentTarget.classList.add("hidden");
    e.currentTarget.classList.remove("flex");
  }
});

// 🎛 STYLE BUTTONS
function setActiveStyle(style) {
  document.querySelectorAll(".style-btn").forEach(b => {
    b.classList.remove("bg-white", "text-black");
    b.classList.add("bg-neutral-800");
  });

  const active = document.querySelector(`[data-style="${style}"]`);
  active.classList.remove("bg-neutral-800");
  active.classList.add("bg-white", "text-black");
}

document.addEventListener("click", async (e) => {
  const styleBtn = e.target.closest(".style-btn");
  if (!styleBtn) return;

  currentStyle = styleBtn.dataset.style;

  setActiveStyle(currentStyle);

  const result = await generateCard({
    image: originalImage,
    title: currentTitle,
    artist: currentArtist,
    style: currentStyle
  });

  currentImage = result.url;
  currentBlob = result.blob;

  document.getElementById("sharePreview").src = currentImage;
});

render();

// 🎨 COLOR DETECTION
function getDominantColor(img) {
  const canvas = document.createElement("canvas");
  const ctx = canvas.getContext("2d");

  canvas.width = 50;
  canvas.height = 50;

  ctx.drawImage(img, 0, 0, 50, 50);

  const data = ctx.getImageData(0, 0, 50, 50).data;

  let r = 0, g = 0, b = 0;

  for (let i = 0; i < data.length; i += 4) {
    r += data[i];
    g += data[i + 1];
    b += data[i + 2];
  }

  const count = data.length / 4;

  return {
    r: Math.round(r / count),
    g: Math.round(g / count),
    b: Math.round(b / count),
  };
}

// 🎯 GENERATE CARD
async function generateCard({ image, title, artist, style }) {
  const canvas = document.createElement("canvas");
  const ctx = canvas.getContext("2d");

  canvas.width = 1080;
  canvas.height = 1350;

  const img = new Image();
  img.crossOrigin = "anonymous";
  img.src = image;

  await new Promise((res) => (img.onload = res));

  const color = getDominantColor(img);

  // BLUR
// detectar soporte
if ("filter" in ctx) {
  // ✅ blur real (moderno)
  ctx.filter = "blur(30px)";
  ctx.drawImage(img, -100, -100, canvas.width + 200, canvas.height + 200);
  ctx.filter = "none";

} else {
  // 🔥 fallback (simulación mejorada)
for (let i = 0; i < 20; i++) {
  const scale = 1 + i * 0.02;
  ctx.globalAlpha = 0.05;
  ctx.drawImage(
    img,
    canvas.width * (1 - scale) / 2,
    canvas.height * (1 - scale) / 2,
    canvas.width * scale,
    canvas.height * scale
  );
}
ctx.globalAlpha = 1;
}

ctx.fillStyle = "rgba(0,0,0,0.4)";
ctx.fillRect(0, 0, canvas.width, canvas.height);


  // STYLES
  if (style === "vibrant") {
    ctx.fillStyle = `rgba(${color.r},${color.g},${color.b},0.35)`
    ctx.fillRect(0, 0, canvas.width, canvas.height);

    ctx.fillStyle = "rgba(0,0,0,0.4)";
    ctx.fillRect(0, 0, canvas.width, canvas.height);

  } else if (style === "dark") {
    ctx.fillStyle = "rgba(0,0,0,0.7)";
    ctx.fillRect(0, 0, canvas.width, canvas.height);

  } else {
    ctx.fillStyle = "rgba(20,20,20,0.9)";
    ctx.fillRect(0, 0, canvas.width, canvas.height);
  }

  // COVER
const size = 720;
const x = (canvas.width - size) / 2;
const y = 150; // 🔥 ESTA LÍNEA FALTABA

ctx.drawImage(img, x, y, size, size);

  // 🔥 TEXTO VERTICAL
ctx.save();

// mover origen al lado izquierdo del cover
ctx.translate(x - 40, y + size); 

// rotar -90 grados
ctx.rotate(-Math.PI / 2);

// estilo
ctx.font = "900 60px sans-serif";
ctx.fillStyle = "rgba(255, 107, 61,0.35)"; // color vibrante con opacidad

// dibujar
drawSpacedText(ctx, "LISTEN NOW", 0, 0, 25);

ctx.restore();

  // TEXT
  const padding = 100;
  ctx.textAlign = "left";

  // TÍTULO
  ctx.font = "900 47px sans-serif";
  ctx.fillStyle = "white";

  const lastY = wrapText(ctx, title, padding, 1000, canvas.width - padding * 2, 60);


    ctx.font = "25px sans-serif";
ctx.fillStyle = "rgba(255,255,255,0.7)";
ctx.fillText("www.madnessmusicgroup.com", padding, canvas.height - 65);

// ARTISTA
  ctx.font = "40px sans-serif";
  ctx.fillStyle = "rgba(255,255,255,0.6)";
  ctx.fillText(artist, padding, lastY + 85);

  ctx.font = "900 40px sans-serif";
ctx.fillStyle = "#fff";

  // 🔥 LOGO
const logo = new Image();
logo.crossOrigin = "anonymous";
logo.src = "/logo.png"; // asegúrate que exista en /public

try {
  await new Promise((res) => (logo.onload = res));

  const logoWidth = 250;
  const logoHeight = 80;

  ctx.globalAlpha = 0.9;

  ctx.drawImage(
    logo,
    canvas.width - logoWidth - 50,   // derecha
    canvas.height - logoHeight - 50, // abajo
    logoWidth,
    logoHeight
  );

  ctx.globalAlpha = 1;
} catch {}

  // GLASS
  ctx.strokeStyle = "rgba(255,255,255,0.12)";
  ctx.lineWidth = 2;
  ctx.strokeRect(40, 40, canvas.width - 80, canvas.height - 80);

  // EXPORT
  const blob = await new Promise((resolve) =>
    canvas.toBlob(resolve, "image/png")
  );

  return { blob, url: URL.createObjectURL(blob) };
}

// TEXT WRAP
function wrapText(ctx, text, x, y, maxWidth, lineHeight) {
  const words = text.split(" ");
  let line = "";
  let currentY = y;

  for (let n = 0; n < words.length; n++) {
    const test = line + words[n] + " ";
    const width = ctx.measureText(test).width;

    if (width > maxWidth && n > 0) {
      ctx.fillText(line, x, currentY);
      line = words[n] + " ";
      currentY += lineHeight;
    } else {
      line = test;
    }
  }

  ctx.fillText(line, x, currentY);
  return currentY;
}

function setActiveStyle(style) {
  document.querySelectorAll(".style-btn").forEach(b => {
    b.classList.remove("bg-accent", "text-white");
    b.classList.add("bg-neutral-800");
  });

  const active = document.querySelector(`[data-style="${style}"]`);
  active.classList.remove("bg-neutral-800");
  active.classList.add("bg-accent", "text-white");
}

function showToast(message) {
  const toast = document.createElement("div");

  toast.textContent = message;

  toast.className = `
    fixed bottom-20 left-1/2 -translate-x-1/2
    bg-accent text-white px-4 py-2 rounded-xl
    text-sm shadow-lg z-[9999]
    opacity-0 transition-all duration-300
  `;

  document.body.appendChild(toast);

  setTimeout(() => {
    toast.classList.remove("opacity-0");
    toast.classList.add("opacity-100");
  }, 50);

  setTimeout(() => {
    toast.classList.remove("opacity-100");
    toast.classList.add("opacity-0");

    setTimeout(() => toast.remove(), 200);
  }, 3000);
}

function drawSpacedText(ctx, text, x, y, spacing = 2) {
  let currentX = x;
  for (let char of text) {
    ctx.fillText(char, currentX, y);
    currentX += ctx.measureText(char).width + spacing;
  }
}
</script>
