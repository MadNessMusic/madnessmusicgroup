        >
          ▶
        </a>

        <span class="text-[11px] tracking-widest uppercase text-white/80">
          Escuchar en Spotify
        </span>

      </div>
    </div>
  </div>

  <!-- INFO -->
  <div class="mt-4">

    <!-- TITLE -->
    <p class="font-anton text-lg tracking-tight">
      ${release.title}
    </p>

    <!-- ARTIST -->
    <p class="text-sm text-base-content/60">
      ${release.artist}
    </p>

    <!-- META -->
    <div class="mt-3 flex items-center gap-2 text-[10px] tracking-widest uppercase">

      <span class="text-base-content/50">
        ${release.type}
      </span>

      <span class="w-1 h-1 rounded-full bg-accent/50"></span>

      <span class="${
        release.source === "madness"
          ? "text-accent font-medium"
          : "text-base-content/40"
      }">
        ${release.source === "madness" ? "MadNess" : "Supported"}
      </span>

    </div>

    <!-- TYPE DOT -->
    <span class="inline-block mt-2 w-2 h-2 rounded-full ${
      release.type === "Single"
        ? "bg-accent"
        : release.type === "EP"
        ? "bg-accent/60 ring-1 ring-accent/30"
        : "bg-accent/30 ring-1 ring-accent/20"
    }"></span>

