---
import Layout from "../layouts/Layout.astro";
import { playlists } from "../data/playlists";
import type { Playlist } from "../data/playlists";
import { getSpotifyPlaylist } from "../lib/spotify";
import Navbar from "@/components/Navbar.astro";

async function enrich(p: Playlist): Promise<Playlist> {

  if (!p.spotifyId) {
    return {
      ...p,
      image: p.cover
    };
  }

  try {

    const s = await getSpotifyPlaylist(p.spotifyId);

    return {
      ...p,
      title: s.name ?? p.title,
      description: s.description ?? p.description,
      image: s.images?.[0]?.url ?? p.cover
    };

  } catch {

    return {
      ...p,
      image: p.cover
    };

  }

}

const enriched = await Promise.all(playlists.map(enrich));
---
<Layout />
<Navbar />

<section class="max-w-7xl mx-auto px-6 py-24">

<h1
class="text-5xl font-anton mb-14"
data-i18n="playlists.title">
</h1>

<input
id="search"
placeholder="Search playlists..."
data-i18n-placeholder="playlists.search"
class="w-full md:w-96 bg-neutral-900 px-5 py-3 rounded-xl mb-10"
/>

<select
id="genreFilter"
class="bg-neutral-900 px-4 py-3 rounded-xl mb-10"
>
<option
value=""
data-i18n="playlists.genres.all">
</option>
</select>

<div
id="grid"
class="grid grid-cols-2 md:grid-cols-4 gap-8"
></div>

</section>

<script define:vars={{ playlists: enriched }}>

const grid = document.getElementById("grid")
const search = document.getElementById("search")
const genreFilter = document.getElementById("genreFilter")

let filtered = playlists

// detectar géneros
const genres = [...new Set(
playlists.flatMap(p => p.genre ?? [])
)]

genres.forEach(g => {

const o = document.createElement("option")

o.value = g
o.textContent = g

genreFilter.appendChild(o)

})

// render
function render(){

grid.innerHTML = ""

filtered.forEach(p => {

const el = document.createElement("a")

el.href = "/playlists/" + p.id
el.className = "group"

el.innerHTML = `

<div class="aspect-square overflow-hidden rounded-xl">

<img
src="${p.image}"
class="w-full h-full object-cover group-hover:scale-105 transition"
/>

</div>

<h2 class="font-anton mt-4">
${p.title}
</h2>

<p class="text-sm opacity-60">
${p.description}
</p>

`

grid.appendChild(el)

})

}

// filtros
function applyFilters(){

const q = search.value.toLowerCase()
const g = genreFilter.value

filtered = playlists.filter(p => {

const matchSearch =
p.title.toLowerCase().includes(q) ||
p.description.toLowerCase().includes(q)

const matchGenre =
!g || (p.genre ?? []).includes(g)

return matchSearch && matchGenre

})

render()

}

search.addEventListener("input", applyFilters)
genreFilter.addEventListener("change", applyFilters)

render()

</script>