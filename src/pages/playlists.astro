---
export const revalidate = 60;

import Layout from "../layouts/Layout.astro";
import { playlists } from "../data/playlists";
import type { Playlist } from "../data/playlists";
import { getSpotifyPlaylist } from "../lib/spotify";
import Navbar from "@/components/Navbar.astro";

async function enrich(playlist: Playlist): Promise<Playlist> {
  if (!playlist.spotifyId) {
    return {
      ...playlist,
      image: playlist.cover,
    };
  }

  try {
    const spotify = await getSpotifyPlaylist(playlist.spotifyId);

    return {
      ...playlist,
      title: spotify.name ?? playlist.title,
      description: spotify.description ?? playlist.description,
      image: spotify.images?.[0]?.url ?? playlist.cover,
    };
  } catch (error) {
    console.error("Spotify playlist fallback:", playlist.spotifyId, error);

    return {
      ...playlist,
      image: playlist.cover,
    };
  }
}

const enriched = await Promise.all(playlists.map(enrich));
---

<Layout>
  <Navbar />

  <section class="max-w-7xl mx-auto px-6 py-24">
    <h1 class="text-5xl font-anton mb-14">
      Playlists curadas
    </h1>

    <input
      id="search"
      placeholder="Buscar playlists..."
      class="w-full md:w-96 bg-neutral-900 px-5 py-3 rounded-xl mb-10"
    />

    <select id="genreFilter" class="bg-neutral-900 px-4 py-3 rounded-xl mb-10">
      <option value="">Todos los géneros</option>
    </select>

    <div id="grid" class="grid grid-cols-2 md:grid-cols-4 gap-8"></div>
  </section>

  <script define:vars={{ playlists: enriched }}>
    const grid = document.getElementById("grid");
    const search = document.getElementById("search");
    const genreFilter = document.getElementById("genreFilter");

    let filtered = playlists;

    const genres = [...new Set(playlists.flatMap((p) => p.genre ?? []))];

    genres.forEach((genre) => {
      const option = document.createElement("option");
      option.value = genre;
      option.textContent = genre;
      genreFilter.appendChild(option);
    });

    function render() {
      grid.innerHTML = "";

      filtered.forEach((playlist) => {
        const el = document.createElement("a");

        el.href = `/playlists/${playlist.id}`;
        el.className = "group";

        el.innerHTML = `
          <div class="aspect-square overflow-hidden rounded-xl">
            <img
              src="${playlist.image}"
              class="w-full h-full object-cover group-hover:scale-105 transition"
            />
          </div>

          <h2 class="font-anton mt-4">${playlist.title}</h2>
          <p class="text-sm opacity-60">${playlist.description}</p>
        `;

        grid.appendChild(el);
      });
    }

    function applyFilters() {
      const query = search.value.toLowerCase();
      const genre = genreFilter.value;

      filtered = playlists.filter((playlist) => {
        const matchSearch =
          playlist.title.toLowerCase().includes(query) ||
          playlist.description.toLowerCase().includes(query);

        const matchGenre = !genre || (playlist.genre ?? []).includes(genre);

        return matchSearch && matchGenre;
      });

      render();
    }

    search.addEventListener("input", applyFilters);
    genreFilter.addEventListener("change", applyFilters);

    render();
  </script>
</Layout>
