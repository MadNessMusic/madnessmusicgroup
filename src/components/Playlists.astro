---
import type { Playlist } from "../data/playlists";
import { playlists } from "../data/playlists";
import { getSpotifyPlaylist } from "../lib/spotify";
import { t } from "../i18n/utils";

const lang = "es";

async function getPlaylistData(item: Playlist): Promise<Playlist> {
  if (!item.spotifyId) {
    return {
      ...item,
      image: item.cover,
      spotifyUrl: item.spotifyUrl ?? "#",
      trackCount: 0,
      followers: 0
    };
  }

  try {
    const spotify = await getSpotifyPlaylist(item.spotifyId);

    return {
      ...item,
      title: spotify.name || item.title,
      description: spotify.description || item.description,
      image: spotify.images?.[0]?.url || item.cover,
      spotifyUrl: spotify.external_urls?.spotify || item.spotifyUrl,
      trackCount: spotify.tracks?.total ?? 0,
      followers: spotify.followers?.total ?? 0
    };

  } catch {
    return {
      ...item,
      image: item.cover,
      spotifyUrl: item.spotifyUrl ?? "#",
      trackCount: 0,
      followers: 0
    };
  }
}

// filtros
const featuredRaw = playlists.filter(p => p.status === "featured");
const evergreenRaw = playlists.filter(p => p.status === "evergreen");

// fetch
const featured = await Promise.all(featuredRaw.map(getPlaylistData));
const evergreen = await Promise.all(evergreenRaw.map(getPlaylistData));

const evergreenLimited = evergreen.slice(0, 4);
---

<div class="mx-auto px-6 mb-20">
  <div class="flex items-center gap-10">
    <span class="block w-30 h-px bg-white/10"></span>
    <span class="text-2xl tracking-[0.7em] uppercase opacity-20">
      {t("section.playlists", lang)}
    </span>
    <span class="flex-1 h-px bg-white/10"></span>
  </div>
</div>

<section id="playlists" class="py-10">

  <!-- HEADER -->
  <div class="max-w-3xl mb-24">
    <h2 class="text-5xl font-anton mb-8">
      {t("playlists.title", lang)}
    </h2>

    <p class="opacity-60 text-1xl leading-relaxed">
      {t("playlists.intro", lang)}
    </p>
  </div>

  <!-- FEATURED -->
  <div class="space-y-20 md:space-y-28 mb-40">
    {featured.map((item, i) => (
      <a
        href={`/playlists/${item.id}`}
        class={`block group`}
      >
        <div class="grid grid-cols-12 gap-6 md:gap-12 items-center">

          <div class={`col-span-12 md:col-span-4 ${i % 2 === 1 ? "md:col-start-9" : ""}`}>
            <img
              src={item.image}
              alt={item.title}
              class="w-full rounded-xl"
            />
          </div>

          <div class={`col-span-12 md:col-span-8 ${i % 2 === 1 ? "md:col-start-1 md:row-start-1" : ""}`}>
            <h4 class="font-anton text-xl mt-4">
              {item.title}
            </h4>

            <p class="opacity-55">
              {item.description}
            </p>

            <p class="opacity-40 text-xs mt-2">
              • {(item.followers ?? 0).toLocaleString()} {t("playlist.saves", lang)}
            </p>

            <span class="text-xs uppercase opacity-40">
              {t("playlist.view", lang)}
            </span>
          </div>

        </div>
      </a>
    ))}
  </div>

  <!-- GRID -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-10">
    {evergreenLimited.map((item) => (
      <a href={`/playlists/${item.id}`} class="group">

        <img
          src={item.image}
          alt={item.title}
          class="rounded-xl"
        />

        <h4 class="font-anton mt-3">
          {item.title}
        </h4>

        <p class="opacity-50 text-sm">
          {item.description}
        </p>

        <p class="text-xs opacity-40">
          • {(item.followers ?? 0).toLocaleString()} {t("playlist.saves", lang)}
        </p>

      </a>
    ))}
  </div>

  <!-- CTA -->
  <div class="text-center mt-20">
    <a href="/playlists" class="btn-tactical px-12 py-4">
      {t("playlists.cta", lang)}
    </a>
  </div>

</section>