---
import LogoLight from "../assets/MadNess Music Group - Logo White.png";
import LogoDark from "../assets/MadNess Music Group - Logo Black.png";
import "../styles/global.css";
---

<section id="hero" class="relative min-h-screen flex items-center">
  <div class="hero-content">
    <div class="grid grid-cols-12 items-center">
      <div class="col-span-12 md:col-span-6 md:col-start-3">
        <div class="hero-logo-wrap">
          <img
            src={LogoDark.src}
            alt="Madness Music Group"
            class="hero-logo hero-logo-light"
          />

          <img
            src={LogoLight.src}
            alt="Madness Music Group"
            class="hero-logo hero-logo-dark"
          />
        </div>

        <span
          class="absolute right-0.5 top-2/6 -translate-y-1/2 text-[25vw] font-anton opacity-[0.02] select-none"
          aria-hidden="true"
        >
          MADNESS
        </span>

        <div class="pt-20 sm:pt-28 md:pt-32">
<span class="block text-2xl tracking-wider uppercase opacity-60 mb-8">
  <span class="text-accent">Sello Independiente</span> · Distribución · Plataforma Musical
</span>

          <p class="text-sm md:text-base opacity-70 leading-relaxed max-w-105 mb-15">
  Lanzamos, distribuímos y apoyamos artistas emergentes mientras construímos un ecosistema curado para la música contemporánea.
</p>

        <div class="flex gap-4 flex-wrap">
  <a
    href="#playlists"
    class="inline-flex items-center justify-center px-9 py-4 border border-[#ed7651]/70 rounded-full text-[11px] tracking-[0.45em] uppercase opacity-70 transition-all duration-300 ease-out hover:opacity-100 hover:border-white hover:-translate-y-0.5"
  >
    Explorar
  </a>

  <a
    href="/submit"
    class="inline-flex items-center justify-center px-9 py-4 bg-[#ed7651] text-white rounded-full text-[11px] tracking-[0.45em] uppercase transition-all duration-300 ease-out hover:-translate-y-0.5 hover:shadow-[0_12px_40px_rgba(255,255,255,0.25)]"
  >
    Enviar música
  </a>
</div>
        </div>
      </div>
    </div>
  </div>
</section>
