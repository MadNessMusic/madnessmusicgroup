---
export const revalidate = 60;

import "../styles/global.css";

interface ReleaseView {
  spotifyId: string;
  title: string;
  artist: string;
  releaseDate: string;
  releasePrecision: string;
  type: "single" | "ep" | "album";
  source: "supported" | "madness";
  image: string;
  url: string;
  tracks: {
    id: string;
    title: string;
    preview: string | null;
  }[];
}

function formatReleaseDate(date: string, precision: string) {
  if (precision === "year") return date;

  if (precision === "month") {
    const [y, m] = date.split("-");
    return `${m}/${y}`;
  }

  const d = new Date(date);

  return d.toLocaleDateString("es-MX", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}

function normalizeDate(date: string, precision: string) {
  if (precision === "year") return new Date(`${date}-12-31`);
  if (precision === "month") return new Date(`${date}-28`);
  return new Date(date);
}

function detectReleaseType(
  albumType?: string,
  tracks?: number
): "single" | "ep" | "album" {

  if (albumType === "album") return "album";

  if (tracks && tracks >= 2 && tracks <= 6) return "ep";

  return "single";
}

import type { Playlist } from "../data/playlists";
import { playlists } from "../data/playlists";
import { releases } from "../data/releases";
import { getSpotifyPlaylist, getSpotifyAlbum } from "../lib/spotify";

async function getReleaseData(item: {
  spotifyAlbumId: string;
  fallbackCover: string;
  source: "supported" | "madness";
}): Promise<ReleaseView> {
  try {
    const album = await getSpotifyAlbum(item.spotifyAlbumId);

    // 🚨 fallback si Spotify falla o rate limit
    if (!album) {
      return {
        spotifyId: item.spotifyAlbumId,
        title: "Untitled",
        artist: "Unknown artist",
        releaseDate: "",
        releasePrecision: "day",
        type: "single",
        image: item.fallbackCover,
        url: "#",
        tracks: [],
        source: item.source,
      };
    }

    return {
      spotifyId: album.id,
      title: album.title,
      artist: album.artist,
      releaseDate: album.releaseDate,
      releasePrecision: album.releasePrecision,

      // 🔥 ahora sí usamos tracks correctamente
      type: detectReleaseType(album.type, album.tracks?.length),
      source: item.source,

      image: album.image || item.fallbackCover,
      url: album.url,

      // ✅ tracks reales
      tracks: album.tracks ?? [],
    
    };

  } catch (e) {
    console.error("Album error:", e);

    return {
      spotifyId: item.spotifyAlbumId,
      title: "Untitled",
      artist: "Unknown artist",
      releaseDate: "",
      releasePrecision: "day",
      type: "single",
      source: item.source,
      image: item.fallbackCover,
      url: "#",
      tracks: [],
    };
  }
}



async function fetchReleasesInBatches() {
  const batchSize = 5;
  const results: ReleaseView[] = [];

  for (let i = 0; i < releases.length; i += batchSize) {
    const batch = releases.slice(i, i + batchSize);

    const res = await Promise.allSettled(
      batch.map((item) =>
        getReleaseData({
          spotifyAlbumId: item.spotifyAlbumId,
          fallbackCover: item.cover,
          source: item.source,
        })
      )
    );

    for (const r of res) {
if (r.status === "fulfilled") {
  results.push(r.value);
} else {
  console.error("Batch item failed:", r.reason);
}
    }
  }

  return results;
}

const allReleases: ReleaseView[] = (await fetchReleasesInBatches())
  .sort((a, b) => {
    const dateA = normalizeDate(a.releaseDate, a.releasePrecision);
    const dateB = normalizeDate(b.releaseDate, b.releasePrecision);
    return dateB.getTime() - dateA.getTime();
  });

const releasesData = allReleases.slice(0, 8);

async function getPlaylistData(item: Playlist): Promise<Playlist> {

  if (!item.spotifyId) {
    return { ...item, image: item.cover };
  }

  try {

    const spotify = await getSpotifyPlaylist(item.spotifyId);

    return {
      ...item,
      title: spotify?.name || item.title,
      description: spotify?.description || item.description,
      image: spotify?.images?.[0]?.url || item.cover,
    };

  } catch {

    return { ...item, image: item.cover };

  }
}

const featuredRaw = playlists.filter(p => p.status === "featured");

const featured = await Promise.all(
  featuredRaw.map(getPlaylistData)
);

const featuredPlaylist = featured[0];
